DATABASE_URL=sqlite+aiosqlite:///./vizhi.db

# Use Hugging Face as the current real inference backend.
INFERENCE_BACKEND=huggingface
HF_TOKEN=hf_your_token_here
HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1

# Optional: map Vizhi aliases to real backend model ids.
INFERENCE_MODEL_MAP={"llama/meta-llama/Llama-3.1-8B-Instruct":"meta-llama/Llama-3.1-8B-Instruct:fastest"}

# Tomorrow: switch to your own OpenAI-compatible deployment.
# INFERENCE_BACKEND=custom
# CUSTOM_INFERENCE_BASE_URL=http://localhost:8001/v1
# CUSTOM_INFERENCE_API_KEY=

# Optional fallback order: try custom first, then Hugging Face.
# INFERENCE_BACKEND=custom,huggingface


# set -a
# source .env
# set +a
